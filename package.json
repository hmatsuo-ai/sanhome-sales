{
  "name": "sanhome-sales",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.cjs",
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "prisma generate && cross-env PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:all": "node scripts/migrate-all-databases.mjs",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react-big-calendar": "^1.16.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
