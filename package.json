    "@types/pg": "^8.16.0",
    "@types/react-big-calendar": "^1.16.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.3",
    "ts-node": "^10.9.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
