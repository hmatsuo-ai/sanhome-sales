{
  "name": "sanhome-sales",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node scripts/with-private-env.cjs npx next dev",
    "build": "node scripts/with-private-env.cjs npx prisma migrate deploy && node scripts/with-private-env.cjs npx next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "node scripts/with-private-env.cjs npx tsx prisma/seed.ts",
    "db:migrate": "node scripts/with-private-env.cjs npx prisma migrate dev",
    "db:generate": "node scripts/with-private-env.cjs npx prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@vercel/blob": "^0.27.3",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
