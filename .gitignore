# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# ローカル DB ファイル（本番は PostgreSQL）
*.db
*.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env（秘密は private/.env.local のみ。テンプレートはコミットする）
.env
.env.development
.env.production
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# ローカル機密（private 内は README / この .gitignore だけ Git 管理）
private/*
!private/README.md
!private/.gitignore
