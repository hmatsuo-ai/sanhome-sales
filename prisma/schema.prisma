// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon 等の pooler 用 URL とは別に、マイグレーション用の直結 URL（Vercel では DATABASE_URL_UNPOOLED）
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("groups")
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password      String     @default("password")
  role          String     @default("sales") // "sales" or "admin"
  isActive      Boolean    @default(true) @map("is_active") // false = 凍結

  groupId       String?    @map("group_id")
  group         Group?     @relation(fields: [groupId], references: [id])
  createdAt     DateTime   @default(now()) @map("created_at")
  expenses      Expense[]
  sales         Sale[]
  assignedSales Sale[]     @relation("SaleAssignees")
  schedules     Schedule[]
  feedbacks    Feedback[]

  @@index([role, isActive])
  @@map("users")
}

model Expense {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  date            DateTime
  category        String
  amount          Int
  receiptImageUrl String?  @map("receipt_image_url")
  memo            String?
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([userId])
  @@map("expenses")
}

model Sale {
  id             String    @id @default(uuid())
  userId         String    @map("user_id") // 登録者
  date           DateTime
  projectName    String    @map("project_name")
  category       String    // "いい部屋ネット" | "仲介" | "事業利益" | "賃貸管理" | "設計"
  salesAmount    Int       @map("sales_amount")
  grossProfit    Int       @map("gross_profit")
  settlementDate DateTime  @default(now()) @map("settlement_date") // 必須化
  isSettled      Boolean   @default(false) @map("is_settled") // 手動決済フラグ
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignees      User[]    @relation("SaleAssignees") // 複数担当者
  profitRatios   String?   @map("profit_ratios") // 担当者ごとの粗利配分割合 (JSON文字列: {userId: ratio})

  @@index([date])
  @@index([userId])
  @@map("sales")
}

model Schedule {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  title     String
  location  String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([startTime])
  @@index([userId])
  @@map("schedules")
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  body      String   // 要望・修正依頼の内容
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedback")
}
