# 環境変数テンプレート（このファイルは Git にコミットしてよい）
#
# ローカル開発: 以下をコピーして private/.env.local を新規作成し、値を埋める。
#   sanhome-sales/private/.env.local  ← API キー・DB URL（Git / Vercel には乗せない）
#
# Vercel 本番: 同じキーをダッシュボード Environment Variables に設定する。

# PostgreSQL（ローカル例。本番は Neon / Supabase / Vercel Postgres 等の URL）
DATABASE_URL="postgresql://username:password@localhost:5432/sanhome_sales_db"
# Vercel Blob（プロジェクトに Blob Storage を接続すると自動設定されることが多い）
BLOB_READ_WRITE_TOKEN=""
# NextAuth / Auth.js（本番: Vercel の Environment Variables に設定）
AUTH_SECRET="generate-a-long-random-string"
AUTH_URL="http://localhost:3000"
GEMINI_API_KEY="your-gemini-api-key-here"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
